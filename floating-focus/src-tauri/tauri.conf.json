{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Floating Focus",
  "version": "6.0.0",
  "identifier": "com.floatingfocus.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Floating Focus",
        "label": "main",
        "width": 300,
        "height": 285,
        "minWidth": 300,
        "minHeight": 285,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "center": false,
        "x": 60,
        "y": 60
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico", "icons/icon.png"]
  }
}
